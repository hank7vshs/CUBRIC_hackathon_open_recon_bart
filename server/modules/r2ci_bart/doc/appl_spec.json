{
  "general": {
    "name": { "en": "Open Recon R2CI App" },
    "version": "1.0.0",
    "vendor": "SHSTeam",
    "information": { "en": "This is a tool to reconstruct datasets with BART." },
    "id": "OpenReconR2CI",
	"regulatory_information":{
		"device_trade_name":"OpenReconR2CI",
        "production_identifier":"1.0.0",
        "manufacturer_address":"Erlangen",
        "made_in":"Germany",
        "manufacture_date":"2025/09/05",
        "material_number":"1337",
        "gtin":"1337",
        "udi":"000000000000000000000000000",
        "safety_advices":"",
        "special_operating_instructions":"",
        "additional_relevant_information":""
	}
  },
  "reconstruction": {
    "transfer_protocol": {
      "protocol": "ISMRMRD",
      "version": "1.4.1"
    },
    "port": 9002,
    "emitter": "raw",
    "injector": "compleximage",
    "can_process_adjustment_data": false,
    "can_use_gpu": true,
    "min_count_required_gpus": 1,
    "min_required_gpu_memory": 2048,
    "min_required_memory": 4096,
    "min_count_required_cpu_cores": 1,
    "content_qualification_type": "RESEARCH",
	"require_readout_filter_off": true,
	"channel_compression":
	{
		"require_state":"off",
		"require_number_target_channels": 12
	}
  },
  "parameters":[
    {	
        "id":"numCoilIntId",
        "type":"int",
        "label":{
            "en": "#Coils"
        },
        "information":{
            "en": "Number of coils for reconstruction: -1 = all coils (default)"
        },
        "minimum": -1,
        "maximum": 64,
        "default": -1,
        "unit": {
            "en": "."
        }
    },
    {
      	"id":"picsFlagsId",
        "type":"string",
        "label":{
        "en": "PICS Flags"
        },
        "information":{
            "en": "String defining the flags passed to BART's parallel imaging and compressed sensing reconstruction tool (PICS)."
        },
        "default": "-e -S",
        "isLargeText" : false
    }
	]
}
